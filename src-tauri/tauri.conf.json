{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Markdowner",
  "version": "0.260527.4",
  "identifier": "dev.chann.markdowner",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://127.0.0.1:14238",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "plugins": {
    "cli": {
      "description": "Markdowner CLI",
      "args": [
        {
          "name": "path",
          "index": 1,
          "takesValue": true,
          "description": "Path to a file or directory to open"
        }
      ]
    }
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Markdowner",
        "width": 1440,
        "height": 920,
        "minWidth": 380,
        "minHeight": 720,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self' customprotocol: asset:",
        "connect-src": "ipc: http://ipc.localhost",
        "img-src": "'self' asset: http://asset.localhost blob: data:",
        "style-src": "'self' 'unsafe-inline'"
      },
      "devCsp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "app",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "13.0",
      "signingIdentity": "-"
    }
  }
}
