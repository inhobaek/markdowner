{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Markdowner",
  "version": "0.260622.1",
  "identifier": "dev.chann.markdowner",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://127.0.0.1:14238",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "plugins": {
    "cli": {
      "description": "Markdowner CLI",
      "args": [
        {
          "name": "path",
          "index": 1,
          "takesValue": true,
          "description": "Path to a file or directory to open"
        }
      ]
    }
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Markdowner",
        "width": 1440,
        "height": 920,
        "minWidth": 380,
        "minHeight": 720,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self' customprotocol: asset:",
        "connect-src": "ipc: http://ipc.localhost https://us.i.posthog.com https://us-assets.i.posthog.com",
        "img-src": "'self' asset: http://asset.localhost https: blob: data:",
        "style-src": "'self' 'unsafe-inline'"
      },
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$HOME/**",
          "/Volumes/**",
          "$TEMP/**"
        ]
      },
      "devCsp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "app",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": [
          "md",
          "markdown"
        ],
        "name": "Markdown",
        "role": "Editor",
        "rank": "Default",
        "mimeType": "text/markdown",
        "contentTypes": [
          "net.daringfireball.markdown"
        ]
      }
    ],
    "macOS": {
      "minimumSystemVersion": "13.0",
      "signingIdentity": "-"
    }
  }
}
